{
  "ConnectionStrings": {
    "NotesApp": "Host=postgres.notes.local;Port=5432;Username=postgres;Password=postgres;Database=notesdb" //cred will push from git config
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Notes.Middleware.StructuredTelemetryMiddleware": "Information"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": false,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "Telemetry": {
    "MaxBodyBytes": 65536,
    "LogBodyOnStatusGte": 0,
    "SlowRequestThreshold": "00:00:02",
    "ExcludedPrefixes": [ "/scalar", "/swagger", "/openapi", "/_framework" ],
    "ExcludedPaths": [ "/health", "/healthz", "/readyz", "/metrics", "/favicon.ico", "/scalar" ],
    "SensitiveHeaders": [
      "authorization",
      "cookie",
      "set-cookie",
      "x-api-key",
      "x-auth-token",
      "proxy-authorization"
    ],
    "GlobalContext": {
      "service": "notes-api",
      "env": "production"
    }
  }
}


 

 